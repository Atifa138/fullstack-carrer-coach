# ---- Core ----
# IMPORTANT: change this to a long random string in production
SECRET_KEY=change_me_to_a_long_random_secret_string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Database ----
# SQLite (default, zero setup). For Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./careercoach.db

# ---- CORS (your frontend origin) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- AI provider: offline | groq | gemini ----
# "offline" works with no key. For real AI, pick groq or gemini and add a free key below.
AI_PROVIDER=offline

# Groq (free): create a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free): create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Email verification ----
# Set EMAIL_ENABLED=true and fill SMTP_* fields to send real verification emails.
# When false (default), new users are auto-verified so the app works without mail config.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@careercoach.ai
# The base URL of your frontend (used to build the verification link in the email)
APP_BASE_URL=http://localhost:5173
